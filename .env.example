# ==============================================================================
# DATABASE
# ==============================================================================

# Neon Postgres connection string — https://neon.tech
# When creating your Neon project, do NOT enable "Neon Auth".
# Better Auth manages all authentication; only the raw Postgres URL is needed.
DATABASE_URL=

# ==============================================================================
# BETTER AUTH
# ==============================================================================

# Random secret used to sign sessions and tokens.
# Generate one with: openssl rand -base64 32
# Or: npx nanoid
BETTER_AUTH_SECRET=

# Base URL of your application (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000

# Public base URL — exposed to the browser.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================================================
# EMAIL (Resend)
# ==============================================================================

# Resend API key — https://resend.com
# Optional in development: if unset, verification/reset links are printed to
# the server console so local dev works without a real email account.
RESEND_API_KEY=

# Sender address shown in outgoing emails. Must be on a domain you've verified
# in Resend (Resend → Domains → Add Domain, then add the DNS records).
# For quick testing without a domain you can use onboarding@resend.dev, but it
# only delivers to the email on your own Resend account.
EMAIL_FROM=noreply@yourdomain.com

# ==============================================================================
# GOOGLE OAUTH
# ==============================================================================

# Google Cloud OAuth 2.0 client credentials.
# Authorized redirect URI (add both in Google Cloud Console):
#   http://localhost:3000/api/auth/callback/google   (development)
#   https://your-domain.com/api/auth/callback/google (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==============================================================================
# LEMON SQUEEZY (Billing — Freeby Pro)
# ==============================================================================
# Lemon Squeezy is a Merchant of Record: it handles global tax/VAT and pays out
# to countries Stripe doesn't (incl. Egypt). https://www.lemonsqueezy.com
#
# 1. Create a store.
# 2. Create a product "Freeby Pro" with TWO variants:
#       Monthly — $19/month recurring
#       Yearly  — $190/year recurring
# 3. API key:  Avatar menu → Settings → API → Generate
# 4. Store ID: shown on the store's settings page (numeric).
# 5. Variant IDs: open each variant, copy the numeric id from the URL.
# 6. Webhook:  Settings → Webhooks → add endpoint -> /api/lemonsqueezy/webhook
#             subscribe to: subscription_created, subscription_updated,
#             subscription_cancelled, subscription_expired.
#             Copy the signing secret here.
#
# All optional in development — billing surfaces degrade gracefully without them.

LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_MONTHLY=
LEMONSQUEEZY_VARIANT_YEARLY=
LEMONSQUEEZY_WEBHOOK_SECRET=

